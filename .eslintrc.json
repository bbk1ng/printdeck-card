{
  "root": true,
  "env": {
    "browser": true,
    "es2022": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "extends": "eslint:recommended",
  "globals": {
    "process": "readonly"
  },
  "rules": {
    "no-unused-vars": ["error", { "args": "none" }]
  }
}
