{
  "name": "printdeck-card",
  "version": "1.4.0",
  "description": "PrintDeck — a Home Assistant card for Bambu Lab 3D printers (fork of PrintWatch Card)",
  "type": "module",
  "main": "dist/printdeck-card.js",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c --watch",
    "watch:ha": "HA_WWW_DEST=/mnt/homeassistant/www/community/printdeck-card-dev rollup -c --watch",
    "deploy:ha": "HA_WWW_DEST=/mnt/homeassistant/www/community/printdeck-card-dev rollup -c",
    "lint": "eslint src/*",
    "clean": "rimraf dist",
    "test": "node --test test/"
  },
  "keywords": [
    "home-assistant",
    "homeassistant",
    "hacs",
    "bambu-lab",
    "3d-printer"
  ],
  "author": "Boris Milinkovic",
  "contributors": [
    "Steven Hubert (original PrintWatch Card, https://github.com/drkpxl/printwatch-card)"
  ],
  "license": "MIT",
  "dependencies": {
    "@lit/reactive-element": "^2.0.0",
    "lit": "^2.8.0",
    "lit-html": "^3.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0 || ^8.0.0",
    "@babel/preset-env": "^7.20.0 || ^8.0.0",
    "@rollup/plugin-babel": "^6.0.0",
    "@rollup/plugin-commonjs": "^24.0.0 || ^25.0.0 || ^26.0.0",
    "@rollup/plugin-json": "^6.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0 || ^16.0.0",
    "@rollup/plugin-replace": "^5.0.0",
    "@rollup/plugin-terser": "^1.0.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "^3.9.5",
    "rimraf": "^5.0.0 || ^6.0.0",
    "rollup": "^3.0.0 || ^4.0.0"
  }
}
